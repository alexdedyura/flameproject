new ChilliadFerris[3];

public OnObjectMoved(objectid)
{
    //printf("[Public Debug] OnObjectMoved(%d)", objectid);
	
	if(objectid == ChilliadFerris[0])
	{
		if(!ChilliadFerris[2])
		{
			SetTimerEx("Timer_OthersActions", 10000, false, "dd", 0, 2);
			ChilliadFerris[2] = 1;
		}
		else
		{
			SetTimerEx("Timer_OthersActions", 10000, false, "dd", 0, 1);
			ChilliadFerris[2] = 0;
		}
		return 1;
	}
	return 1;
}

forward Timer_OthersActions(playerid, action);
public Timer_OthersActions(playerid, action)
{
	if(action == 1)
	{
		MoveObject(ChilliadFerris[0], -2249.4492, -1565.0581, 485.8748, 10.0);
		MoveObject(ChilliadFerris[1], -1567.35718, -1557.96741, 42.79770, 10.0);
	}
	else if(action == 2)
	{
		MoveObject(ChilliadFerris[0], -1567.27893, -1565.05811, 42.79769, 10.0);
		MoveObject(ChilliadFerris[1], -2249.4966, -1557.9674, 485.8748, 10.0);
	}
	return 1;
} 

